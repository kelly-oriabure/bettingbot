# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# Data APIs
API_FOOTBALL_KEY=your-api-football-key
ODDS_API_KEY=your-odds-api-key

# OpenRouter (optional, for LLM analysis)
OPENROUTER_API_KEY=your-openrouter-key

# Prediction settings
PREDICTION_LEAGUES=39,140,61,135,78,848
# Premier League(39), La Liga(140), Serie A(61), Bundesliga(135), Ligue 1(78), Brasileirao(848)

# Bot settings
FREE_DAILY_LIMIT=3
PRO_DAILY_LIMIT=50
VIP_DAILY_LIMIT=200

# Database
DATABASE_URL=sqlite:///bettingbot.db

# Coolify (set via Coolify env)
COOLIFY_URL=https://coolify.firmoncloud.com
COOLIFY_API_TOKEN=your-coolify-token
